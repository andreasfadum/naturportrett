ANTHROPIC_API_KEY=sk-ant-your-key-here
PORT=3001

# Feedback-routing via Resend (resend.com)
# Hvis RESEND_API_KEY ikke er satt: tilbakemeldinger lagres bare på disk
# og kan fortsatt hentes på /admin/feedback med passord (WORKSHOP_ADMIN_PASSWORD).
RESEND_API_KEY=
# E-post som mottar tilbakemeldinger. Må samsvare med kontoens registrerte
# e-post hvis du IKKE har verifisert et domene hos Resend.
FEEDBACK_RECIPIENT_EMAIL=andreas.haugstad@pbe.oslo.kommune.no
# Avsenderadresse. onboarding@resend.dev funker uten domene-verifisering,
# men kan bytter til en pbe.oslo.kommune.no-adresse senere hvis du verifiserer domenet.
FEEDBACK_FROM_EMAIL=Naturportrett <onboarding@resend.dev>

# Passord for admin-sidene (/admin/feedback og /admin/usage). Uten denne er
# admin-rutene deaktivert (503).
WORKSHOP_ADMIN_PASSWORD=

# Hemmelig salt for IP-anonymisering i usage-loggen (M2/GDPR). IP-er lagres
# aldri rått — kun som saltet hash. Saltet MÅ være hemmelig (IPv4-rommet er
# lite nok til å brute-forces mot en usaltet hash). Settes denne IKKE, brukes
# et tilfeldig salt per prosess (fortsatt sikkert, men sesjons-grupperingen i
# usage-statistikken brytes ved hver omstart). Sett en lang tilfeldig streng.
USAGE_IP_SALT=
