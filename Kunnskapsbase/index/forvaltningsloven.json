      "kapittel": "Kapittel VII – om forskrifter (utdrag)",
      "lovdataUrl": "https://lovdata.no/lov/1967-02-10/%C2%A739"
    },
    {
      "id": "forvaltningsloven-40",
      "nummer": "40",
      "displayNavn": "§ 40",
      "tema": "fravik av forskrift",
      "sitat": "## Kapittel VIII – virkning av feil (sentralt)",
      "kapittel": "Kapittel VII – om forskrifter (utdrag)",
      "lovdataUrl": "https://lovdata.no/lov/1967-02-10/%C2%A740"
    },
    {
      "id": "forvaltningsloven-41",
      "nummer": "41",
      "displayNavn": "§ 41",
      "tema": "virkningen av feil ved behandlingsmåten",
      "sitat": "«Er reglene om\nbehandlingsmåten i denne lov eller forskrifter gitt i medhold av loven ikke\noverholdt ved behandlingen av en sak som gjelder enkeltvedtak, er vedtaket\nlikevel gyldig **når det er grunn til å regne med at feilen ikke kan ha virket\nbestemmende på vedtakets innhold**.»",
      "kapittel": "Kapittel VIII – virkning av feil (sentralt)",
      "lovdataUrl": "https://lovdata.no/lov/1967-02-10/%C2%A741"
    },
    {
      "id": "forvaltningsloven-42",
      "nummer": "42",
      "displayNavn": "§ 42",
      "tema": "utsatt iverksetting",
      "sitat": "underinstans/klageinstans kan beslutte at vedtak\nikke skal iverksettes før klagefrist/klage er avgjort.",
      "kapittel": "Kapittel VIII – virkning av feil (sentralt)",
      "lovdataUrl": "https://lovdata.no/lov/1967-02-10/%C2%A742"
